# =============================================================================
# Jamf Prestage Tool — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# Azure Entra (MSAL) Authentication
# ------------------------------------
# Application (client) ID from your Entra app registration
AZURE_CLIENT_ID=11111111-2222-3333-4444-555566667777

# Authority URL — use /common for multi-tenant, or replace with your tenant ID
# for single-tenant: https://login.microsoftonline.com/<your-tenant-id>
AZURE_AUTHORITY=https://login.microsoftonline.com/common

# Set to true to bypass Azure auth entirely (local dev/testing only)
SKIP_ENTRA_AUTH=false


# Client (UI) Configuration
# ------------------------------------
CLIENT_HOSTNAME=localhost
CLIENT_PORT=443
THEME=dim


# Server (API) Configuration
# ------------------------------------
SERVER_API_HOSTNAME=localhost
SERVER_API_PORT=8443


# Jamf Pro
# ------------------------------------
JAMF_INSTANCE=https://yourorg.jamfcloud.com
JAMF_CLIENT_ID=your-jamf-client-id
JAMF_CLIENT_SECRET=your-jamf-client-secret


# GLPI Asset Management (optional)
# ------------------------------------
# GLPI_INSTANCE=https://glpi.yourorg.com/apirest.php
# GLPI_APP_TOKEN=your-glpi-app-token
# GLPI_USER_TOKEN=your-glpi-user-token


# Aruba ClearPass (optional — used during device retire)
# ------------------------------------
# CLEARPASS_INSTANCE=https://clearpass.yourorg.com/api
# CLEARPASS_CLIENT_ID=your-clearpass-client-id
# CLEARPASS_CLIENT_SECRET=your-clearpass-client-secret


# Logging
# ------------------------------------
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info


# Audit Database (optional)
# ------------------------------------
# Path inside the container where the SQLite audit DB is stored.
# The docker-compose.yml mounts ./audit.db here by default.
# AUDIT_DB_PATH=/app/audit.db
